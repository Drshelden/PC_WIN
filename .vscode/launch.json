{
    "version": "0.2.0",
    "configurations": [

        
        {
            "name": "Debug main (WSL)",
            "type": "cppdbg",
            "request": "launch",
            "program": "/mnt/c/_LOCAL/GitHub/PC_WIN/tests/pcl_hybrid/main",
            "args": ["/mnt/c/_LOCAL/GitHub/PC_WIN/tests/pcl_hybrid/cyl1.xyz"],
            "stopAtEntry": false,
            "cwd": "/mnt/c/_LOCAL/GitHub/PC_WIN/tests/pcl_hybrid",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "pipeTransport": {
                "pipeProgram": "wsl.exe",
                "pipeArgs": ["-e", "/usr/bin/gdb", "--interpreter=mi"],
                "debuggerPath": "/usr/bin/gdb"
            },
            // Map remote (WSL) source paths to local Windows paths so VS Code can open files
            "sourceFileMap": {
                "/mnt/c/_LOCAL/GitHub/PC_WIN": "c:/_LOCAL/GitHub/PC_WIN"
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
        ,
        {
            "name": "Python: Run pcl_hybrid main.py (quad.xyz)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/tests/pcl_hybrid/main.py",
            "args": ["${workspaceFolder}/tests/pcl_hybrid/data/quad.xyz"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/tests/pcl_hybrid",
            "env": {
                "PYTHONPATH": "${workspaceFolder}\\tests\\pcl_hybrid\\build_py39\\Release;${env:PYTHONPATH}",
                "PATH": "${workspaceFolder}\\tests\\pcl_hybrid\\build_py39\\Release;C:\\vcpkg\\installed\\x64-windows\\bin;${env:PATH}"
            }
        }
    ]
}
